                              -- 
                              -- // uart_stubs.kla - Low-level UART routines callable from C
                              -- //
                              -- // Calling convention: args in A-D, return in M
                              -- // These are leaf functions (no calls), so no frame setup needed.
                              -- //
                              -- // Functions:
                              -- //   _uart_tx_hex(val)    - print 32-bit value as 8 hex digits
                              -- //   _uart_newline()      - print CR/LF
                              -- //   _uart_tx_char(ch)    - print single ASCII character
                              -- //   _uart_rx_char()      - blocking receive: wait for a byte, return it in M
                              -- //   _uart_rx_char_nb()   - non-blocking receive: return byte if available, -1 if not
                              -- //
                              -- // Usage from C:
                              -- //   extern void _uart_tx_hex(int val);
                              -- //   extern void _uart_newline(void);
                              -- //   extern void _uart_tx_char(int ch);
                              -- //   extern int  _uart_rx_char(void);
                              -- //   extern int  _uart_rx_char_nb(void);
                              -- 
                              -- // ----------------------------------------------------------------
                              -- // _uart_tx_hex: print register A as 8 hex digits
                              -- // Input: A = value
                              -- // ----------------------------------------------------------------
0x00001360:                   -- _uart_tx_hex:
0x00001360: 00005010          -- TXR A
0x00001364: 00001012          -- RET
                              -- 
                              -- // ----------------------------------------------------------------
                              -- // _uart_newline: print CR/LF
                              -- // ----------------------------------------------------------------
0x00001368:                   -- _uart_newline:
0x00001368: 00005001          -- NEWLINE
0x0000136C: 00001012          -- RET
                              -- 
                              -- // ----------------------------------------------------------------
                              -- // _uart_tx_char: print single ASCII char from A (low 8 bits)
                              -- // We store the value to a scratch word then use TXCHARMEMR
                              -- // Input: A = character value (low 8 bits used)
                              -- // ----------------------------------------------------------------
0x00001370:                   -- _uart_tx_char:
0x00001370: 0000080D 000013AC -- SETR N #_CHAR_BUF
0x00001378: 0000700D          -- MEMSETRR A N
0x0000137C: 0000503D          -- TXCHARMEMR N
0x00001380: 00001012          -- RET
                              -- 
                              -- // ----------------------------------------------------------------
                              -- // _uart_rx_char: blocking receive - wait until a byte arrives
                              -- // Return: M = received byte
                              -- // ----------------------------------------------------------------
0x00001384:                   -- _uart_rx_char:
0x00001384: 0000505C          -- RXRB M
0x00001388: 00001012          -- RET
                              -- 
                              -- // ----------------------------------------------------------------
                              -- // _uart_rx_char_nb: non-blocking receive
                              -- // RXRNB sets zero_flag=1 and leaves M unchanged when FIFO is empty.
                              -- // We test the flag here and return -1 as the no-data sentinel so
                              -- // callers get a plain integer — no flag inspection needed from C.
                              -- // Return: M = received byte, or -1 if no byte available
                              -- // ----------------------------------------------------------------
0x0000138C:                   -- _uart_rx_char_nb:
0x0000138C: 0000506C          -- RXRNB M
0x00001390: 00001001 0000139C -- JMPZ _rxrnb_empty:
0x00001398: 00001012          -- RET
0x0000139C:                   -- _rxrnb_empty:
0x0000139C: 0000080C 00000000 -- SETR M 0
0x000013A4: 0000098C          -- NOTR M
0x000013A8: 00001012          -- RET
