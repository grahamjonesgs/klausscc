                              -- // Test 19: Extended Comparisons, Min/Max, Conditional Calls
                              -- // Tests: CMPLERR, CMPGERR, CMPULTRR, CMPULERR, CMPUGTRR, CMPUGERR,
                              -- //        MINRR, MAXRR, MINURR, MAXURR, JMPR, CALLZ, CALLNZ
                              -- // Expected UART output:
                              -- //   00000001  (CMPLERR: 5 <= 10, jump taken)
                              -- //   00000002  (CMPLERR: 5 <= 5, equal case, jump taken)
                              -- //   00000003  (CMPGERR: 10 >= 5, jump taken)
                              -- //   00000004  (CMPULTRR: unsigned 5 < 0xFFFFFFFF, jump taken)
                              -- //   00000005  (CMPUGTRR: unsigned 0xFFFFFFFF > 5, jump taken)
                              -- //   00000003  (MINRR: min(3, 7) = 3)
                              -- //   00000007  (MAXRR: max(3, 7) = 7)
                              -- //   00000005  (MINURR: unsigned min(5, 0xFFFFFFFF) = 5)
                              -- //   FFFFFFFF  (MAXURR: unsigned max(5, 0xFFFFFFFF) = 0xFFFFFFFF)
                              -- //   0000000A  (CALLZ: conditional call taken when zero flag set)
                              -- //   0000000B  (CALLNZ: conditional call taken when zero flag clear)
                              -- //   0000000C  (JMPR: jump to address in register)
                              -- // Expected 7SEG: 0x13
                              -- // Expected LEDs: 0xFF = all pass
                              -- 
                              -- _start
0x00000000: 0000F013 00000500 -- DELAYV 0x0500
0x00000002: 00003071 00000013 -- 7SEG1V 0x13
0x00000004: 00005001          -- NEWLINE
                              -- 
                              -- // --- CMPLERR: signed less-or-equal (5 <= 10) ---
0x00000005: 00000800 00000005 -- SETR A 5
0x00000007: 00000801 0000000A -- SETR B 10
0x00000009: 00009101          -- CMPLERR A B            // A <= B? yes
0x0000000A: 00001016 00000012 -- JMPLE T1_PASS:
0x0000000C: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF
0x0000000E: 0000501F          -- TXR P
0x0000000F: 00005001          -- NEWLINE
0x00000010: 00001000 00000016 -- JMP T2:
0x00000012:                   -- T1_PASS:
0x00000012: 0000080F 00000001 -- SETR P 0x1
0x00000014: 0000501F          -- TXR P                  // Expect: 00000001
0x00000015: 00005001          -- NEWLINE
                              -- 
                              -- // --- CMPLERR: equal case (5 <= 5) ---
0x00000016:                   -- T2:
0x00000016: 00000800 00000005 -- SETR A 5
0x00000018: 00000801 00000005 -- SETR B 5
0x0000001A: 00009101          -- CMPLERR A B            // A <= B? yes (equal)
0x0000001B: 00001016 00000023 -- JMPLE T2_PASS:
0x0000001D: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF
0x0000001F: 0000501F          -- TXR P
0x00000020: 00005001          -- NEWLINE
0x00000021: 00001000 00000027 -- JMP T3:
0x00000023:                   -- T2_PASS:
0x00000023: 0000080F 00000002 -- SETR P 0x2
0x00000025: 0000501F          -- TXR P                  // Expect: 00000002
0x00000026: 00005001          -- NEWLINE
                              -- 
                              -- // --- CMPGERR: signed greater-or-equal (10 >= 5) ---
0x00000027:                   -- T3:
0x00000027: 00000800 0000000A -- SETR A 10
0x00000029: 00000801 00000005 -- SETR B 5
0x0000002B: 00009301          -- CMPGERR A B            // A >= B? yes
0x0000002C: 00001018 00000034 -- JMPGE T3_PASS:
0x0000002E: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF
0x00000030: 0000501F          -- TXR P
0x00000031: 00005001          -- NEWLINE
0x00000032: 00001000 00000038 -- JMP T4:
0x00000034:                   -- T3_PASS:
0x00000034: 0000080F 00000003 -- SETR P 0x3
0x00000036: 0000501F          -- TXR P                  // Expect: 00000003
0x00000037: 00005001          -- NEWLINE
                              -- 
                              -- // --- CMPULTRR: unsigned less-than (5 < 0xFFFFFFFF) ---
                              -- // In signed: 5 > -1, but unsigned: 5 < 4294967295
0x00000038:                   -- T4:
0x00000038: 00000800 00000005 -- SETR A 5
0x0000003A: 00000801 FFFFFFFF -- SETR B 0xFFFFFFFF
0x0000003C: 00009401          -- CMPULTRR A B           // unsigned A < B? sets carry flag
0x0000003D: 00001005 00000045 -- JMPC T4_PASS:
0x0000003F: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF
0x00000041: 0000501F          -- TXR P
0x00000042: 00005001          -- NEWLINE
0x00000043: 00001000 00000049 -- JMP T5:
0x00000045:                   -- T4_PASS:
0x00000045: 0000080F 00000004 -- SETR P 0x4
0x00000047: 0000501F          -- TXR P                  // Expect: 00000004
0x00000048: 00005001          -- NEWLINE
                              -- 
                              -- // --- CMPUGTRR: unsigned greater-than (0xFFFFFFFF > 5) ---
0x00000049:                   -- T5:
0x00000049: 00000800 FFFFFFFF -- SETR A 0xFFFFFFFF
0x0000004B: 00000801 00000005 -- SETR B 5
0x0000004D: 00009601          -- CMPUGTRR A B           // unsigned A > B? sets greater flag
0x0000004E: 00001017 00000056 -- JMPGT T5_PASS:
0x00000050: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF
0x00000052: 0000501F          -- TXR P
0x00000053: 00005001          -- NEWLINE
0x00000054: 00001000 0000005A -- JMP T6:
0x00000056:                   -- T5_PASS:
0x00000056: 0000080F 00000005 -- SETR P 0x5
0x00000058: 0000501F          -- TXR P                  // Expect: 00000005
0x00000059: 00005001          -- NEWLINE
                              -- 
                              -- // --- MINRR: signed minimum ---
0x0000005A:                   -- T6:
0x0000005A: 00000800 00000003 -- SETR A 3
0x0000005C: 00000801 00000007 -- SETR B 7
0x0000005E: 0000A001          -- MINRR A B              // A = min(A, B) = min(3, 7) = 3
0x0000005F: 00005010          -- TXR A                  // Expect: 00000003
0x00000060: 00005001          -- NEWLINE
                              -- 
                              -- // --- MAXRR: signed maximum ---
0x00000061: 00000800 00000003 -- SETR A 3
0x00000063: 00000801 00000007 -- SETR B 7
0x00000065: 0000A101          -- MAXRR A B              // A = max(A, B) = max(3, 7) = 7
0x00000066: 00005010          -- TXR A                  // Expect: 00000007
0x00000067: 00005001          -- NEWLINE
                              -- 
                              -- // --- MINURR: unsigned minimum ---
                              -- // 5 vs 0xFFFFFFFF: unsigned min = 5
0x00000068: 00000800 00000005 -- SETR A 5
0x0000006A: 00000801 FFFFFFFF -- SETR B 0xFFFFFFFF
0x0000006C: 0000A201          -- MINURR A B             // A = unsigned min(5, 0xFFFFFFFF) = 5
0x0000006D: 00005010          -- TXR A                  // Expect: 00000005
0x0000006E: 00005001          -- NEWLINE
                              -- 
                              -- // --- MAXURR: unsigned maximum ---
0x0000006F: 00000800 00000005 -- SETR A 5
0x00000071: 00000801 FFFFFFFF -- SETR B 0xFFFFFFFF
0x00000073: 0000A301          -- MAXURR A B             // A = unsigned max(5, 0xFFFFFFFF) = 0xFFFFFFFF
0x00000074: 00005010          -- TXR A                  // Expect: FFFFFFFF
0x00000075: 00005001          -- NEWLINE
                              -- 
                              -- // --- CALLZ: conditional call when zero flag set ---
0x00000076: 00000800 00000001 -- SETR A 0x1
0x00000078: 00000850          -- DECR A                 // A = 0, zero flag set
0x00000079: 0000100A 00000095 -- CALLZ SUB_RET_A:
0x0000007B: 00005010          -- TXR A                  // Expect: 0000000A
0x0000007C: 00005001          -- NEWLINE
                              -- 
                              -- // --- CALLNZ: conditional call when zero flag clear ---
0x0000007D: 00000800 00000005 -- SETR A 0x5
0x0000007F: 00000810 00000000 -- ADDV A 0x0             // Clear stale zero flag (A=5, not zero)
0x00000081: 0000100B 00000098 -- CALLNZ SUB_RET_B:
0x00000083: 00005010          -- TXR A                  // Expect: 0000000B
0x00000084: 00005001          -- NEWLINE
                              -- 
                              -- // --- JMPR: jump to address in register ---
0x00000085: 00000800 0000008E -- SETR A JMPR_TARGET:
0x00000087: 00001020          -- JMPR A
0x00000088: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF      // FAIL: should not reach here
0x0000008A: 0000501F          -- TXR P
0x0000008B: 00005001          -- NEWLINE
0x0000008C: 00001000 00000092 -- JMP DONE:
                              -- 
0x0000008E:                   -- JMPR_TARGET:
0x0000008E: 0000080F 0000000C -- SETR P 0xC
0x00000090: 0000501F          -- TXR P                  // Expect: 0000000C
0x00000091: 00005001          -- NEWLINE
                              -- 
0x00000092:                   -- DONE:
0x00000092: 00003070 000000FF -- LEDV 0xFF
0x00000094: 0000F011          -- HALT
                              -- 
                              -- // Subroutines
0x00000095:                   -- SUB_RET_A:
0x00000095: 00000800 0000000A -- SETR A 0xA
0x00000097: 00001012          -- RET
                              -- 
0x00000098:                   -- SUB_RET_B:
0x00000098: 00000800 0000000B -- SETR A 0xB
0x0000009A: 00001012          -- RET
