                              -- // Test 11: I/O Peripherals
                              -- // Tests: LEDV, LEDR, 7SEG1V, 7SEG2V, 7SEGR, 7SEGBLANK, SWR, RGB1V, RGB2V
                              -- // Verification: Visual inspection of LEDs and 7-segment displays.
                              -- //   Each step pauses with DELAYV so the result can be observed.
                              -- //   UART outputs the step number for synchronisation.
                              -- // Expected sequence:
                              -- //   Step 1: LEDs show 0xAA (alternating pattern)
                              -- //   Step 2: LEDs show 0x55 (inverse pattern)
                              -- //   Step 3: LEDs show 0xFF (all on from register)
                              -- //   Step 4: 7-Seg 1 shows 0x1111
                              -- //   Step 5: 7-Seg 2 shows 0x2222
                              -- //   Step 6: 7-Seg shows register value 0xABCD (both displays)
                              -- //   Step 7: 7-Seg goes blank
                              -- //   Step 8: RGB LED 1 set to 0xFF0000
                              -- //   Step 9: RGB LED 2 set to 0x00FF00
                              -- //   Step 10: Switch status read into register and displayed
                              -- // Expected LEDs at end: 0xFF = all pass
                              -- 
                              -- _start
0x00000000: 0000F013 00003000 -- DELAYV 0x3000
0x00000002: 00005001          -- NEWLINE
                              -- 
                              -- // Step 1: LED alternating pattern
0x00000003: 00000800 00000001 -- SETR A 0x1
0x00000005: 00005010          -- TXR A
0x00000006: 00005001          -- NEWLINE
0x00000007: 00003070 000000AA -- LEDV 0xAA
0x00000009: 0000F013 0000FFFF -- DELAYV 0xFFFF
                              -- 
                              -- // Step 2: LED inverse pattern
0x0000000B: 00000800 00000002 -- SETR A 0x2
0x0000000D: 00005010          -- TXR A
0x0000000E: 00005001          -- NEWLINE
0x0000000F: 00003070 00000055 -- LEDV 0x55
0x00000011: 0000F013 0000FFFF -- DELAYV 0xFFFF
                              -- 
                              -- // Step 3: LED from register
0x00000013: 00000800 00000003 -- SETR A 0x3
0x00000015: 00005010          -- TXR A
0x00000016: 00005001          -- NEWLINE
0x00000017: 00000801 000000FF -- SETR B 0xFF
0x00000019: 00003001          -- LEDR B
0x0000001A: 0000F013 0000FFFF -- DELAYV 0xFFFF
                              -- 
                              -- // Step 4: 7-Seg 1
0x0000001C: 00000800 00000004 -- SETR A 0x4
0x0000001E: 00005010          -- TXR A
0x0000001F: 00005001          -- NEWLINE
0x00000020: 00003071 00001111 -- 7SEG1V 0x1111
0x00000022: 0000F013 0000FFFF -- DELAYV 0xFFFF
                              -- 
                              -- // Step 5: 7-Seg 2
0x00000024: 00000800 00000005 -- SETR A 0x5
0x00000026: 00005010          -- TXR A
0x00000027: 00005001          -- NEWLINE
0x00000028: 00003072 00002222 -- 7SEG2V 0x2222
0x0000002A: 0000F013 0000FFFF -- DELAYV 0xFFFF
                              -- 
                              -- // Step 6: 7-Seg from register (both displays)
0x0000002C: 00000800 00000006 -- SETR A 0x6
0x0000002E: 00005010          -- TXR A
0x0000002F: 00005001          -- NEWLINE
0x00000030: 00000801 0000ABCD -- SETR B 0xABCD
0x00000032: 00003041          -- 7SEGR B
0x00000033: 0000F013 0000FFFF -- DELAYV 0xFFFF
                              -- 
                              -- // Step 7: 7-Seg blank
0x00000035: 00000800 00000007 -- SETR A 0x7
0x00000037: 00005010          -- TXR A
0x00000038: 00005001          -- NEWLINE
0x00000039: 00003073          -- 7SEGBLANK
0x0000003A: 0000F013 0000FFFF -- DELAYV 0xFFFF
                              -- 
                              -- // Step 8: RGB LED 1
0x0000003C: 00000800 00000008 -- SETR A 0x8
0x0000003E: 00005010          -- TXR A
0x0000003F: 00005001          -- NEWLINE
0x00000040: 00003074 00FF0000 -- RGB1V 0xFF0000
0x00000042: 0000F013 0000FFFF -- DELAYV 0xFFFF
                              -- 
                              -- // Step 9: RGB LED 2
0x00000044: 00000800 00000009 -- SETR A 0x9
0x00000046: 00005010          -- TXR A
0x00000047: 00005001          -- NEWLINE
0x00000048: 00003075 0000FF00 -- RGB2V 0x00FF00
0x0000004A: 0000F013 0000FFFF -- DELAYV 0xFFFF
                              -- 
                              -- // Step 10: Read switches and display
0x0000004C: 00000800 0000000A -- SETR A 0xA
0x0000004E: 00005010          -- TXR A
0x0000004F: 00005001          -- NEWLINE
0x00000050: 00003012          -- SWR C                 // Read switch state
0x00000051: 00003042          -- 7SEGR C               // Display on 7-seg
0x00000052: 00005012          -- TXR C                 // Output switch value on UART
0x00000053: 00005001          -- NEWLINE
0x00000054: 0000F013 0000FFFF -- DELAYV 0xFFFF
                              -- 
0x00000056: 00003070 000000FF -- LEDV 0xFF
0x00000058: 0000F011          -- HALT
