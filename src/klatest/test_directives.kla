// Test C compiler directives
// Expected output:
//   0000002A  (.word 42 from data section)
//   00000000  (.comm buffer, first word)
//   00000037  (fibonacci result = 55)

.global _start
.extern some_symbol

.text
_start
SETR P 0xFFFFF
COPY O P

// Load the value stored by .word in data section
MEMREADR A my_value:
TXR A
NEWLINE

// Load from .comm buffer (should be zero-initialized)
MEMREADR A buffer:
TXR A
NEWLINE

// Quick fibonacci(9) = 55 to prove code still works
SETR A 9
CALL fibonacci:
TXR M
NEWLINE

HALT

fibonacci:
MEMSETRR O P
DECR P
COPY O P
MINUSV P 4
STIDX E O 0xFFFFFFFF
STIDX F O 0xFFFFFFFE
STIDX G O 0xFFFFFFFD
STIDX H O 0xFFFFFFFC
SETR M 0
COPY F M
SETR H 1
COPY G M
JMP fib_check:
fib_loop:
COPY E F
ADDRR E H
COPY F H
COPY H E
SETR M 1
ADDRR G M
fib_check:
CMPRR G A
JMPLT fib_loop:
COPY M F
LDIDX E O 0xFFFFFFFF
LDIDX F O 0xFFFFFFFE
LDIDX G O 0xFFFFFFFD
LDIDX H O 0xFFFFFFFC
COPY P O
INCR P
MEMREADRR O P
RET

.data
my_value:
.word 0x2A

.comm buffer, 8, 4
