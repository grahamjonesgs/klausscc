                              -- // Test 07: Comparison and Conditional Jumps
                              -- // Tests: CMPRR, CMPRV, JMPZ, JMPNZ, JMPE, JMPNE, JMPS, JMPNS, JMPLT, JMPGT
                              -- // Verification method: Each test outputs a PASS code via TXR.
                              -- //   If a wrong branch is taken, that test outputs FAIL (0xFFFFFFFF) instead.
                              -- // Expected UART output (all pass):
                              -- //   00000001  (JMPZ: taken after DECR to zero)
                              -- //   00000002  (JMPNZ: taken when register not zero)
                              -- //   00000003  (JMPE: taken after CMPRR equal)
                              -- //   00000004  (JMPNE: taken after CMPRR not equal)
                              -- //   00000005  (JMPS: taken when result negative)
                              -- //   00000006  (JMPNS: taken when result positive)
                              -- //   00000007  (JMPLT: taken after signed less-than compare)
                              -- //   00000008  (JMPGT: taken after signed greater-than compare)
                              -- // Expected 7SEG: 0x07
                              -- // Expected LEDs: 0xFF = all pass
                              -- 
                              -- _start
0x00000000: 0000F013 00003000 -- DELAYV 0x3000
0x00000002: 00003071 00000007 -- 7SEG1V 0x07
0x00000004: 00005001          -- NEWLINE
                              -- 
                              -- // --- Test JMPZ: jump if zero ---
0x00000005: 00000800 00000001 -- SETR A 1
0x00000007: 00000850          -- DECR A                // A = 0, zero flag set
0x00000008: 00001001 00000010 -- JMPZ T1_PASS:
0x0000000A: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF     // FAIL
0x0000000C: 0000501F          -- TXR P
0x0000000D: 00005001          -- NEWLINE
0x0000000E: 00001000 00000014 -- JMP T2:
0x00000010:                   -- T1_PASS:
0x00000010: 0000080F 00000001 -- SETR P 0x1
0x00000012: 0000501F          -- TXR P                 // Expect: 00000001
0x00000013: 00005001          -- NEWLINE
                              -- 
                              -- // --- Test JMPNZ: jump if not zero ---
0x00000014:                   -- T2:
0x00000014: 00000800 00000005 -- SETR A 5
0x00000016: 00000810 00000000 -- ADDV A 0x0             // Clear stale zero flag (A=5, not zero)
0x00000018: 00001002 00000020 -- JMPNZ T2_PASS:
0x0000001A: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF
0x0000001C: 0000501F          -- TXR P
0x0000001D: 00005001          -- NEWLINE
0x0000001E: 00001000 00000024 -- JMP T3:
0x00000020:                   -- T2_PASS:
0x00000020: 0000080F 00000002 -- SETR P 0x2
0x00000022: 0000501F          -- TXR P                 // Expect: 00000002
0x00000023: 00005001          -- NEWLINE
                              -- 
                              -- // --- Test JMPE: jump if equal ---
0x00000024:                   -- T3:
0x00000024: 00000800 00000042 -- SETR A 0x42
0x00000026: 00000801 00000042 -- SETR B 0x42
0x00000028: 00000501          -- CMPRR A B             // Equal flag set
0x00000029: 00001003 00000031 -- JMPE T3_PASS:
0x0000002B: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF
0x0000002D: 0000501F          -- TXR P
0x0000002E: 00005001          -- NEWLINE
0x0000002F: 00001000 00000035 -- JMP T4:
0x00000031:                   -- T3_PASS:
0x00000031: 0000080F 00000003 -- SETR P 0x3
0x00000033: 0000501F          -- TXR P                 // Expect: 00000003
0x00000034: 00005001          -- NEWLINE
                              -- 
                              -- // --- Test JMPNE: jump if not equal ---
0x00000035:                   -- T4:
0x00000035: 00000800 00000042 -- SETR A 0x42
0x00000037: 00000801 00000099 -- SETR B 0x99
0x00000039: 00000501          -- CMPRR A B             // Not equal
0x0000003A: 00001004 00000042 -- JMPNE T4_PASS:
0x0000003C: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF
0x0000003E: 0000501F          -- TXR P
0x0000003F: 00005001          -- NEWLINE
0x00000040: 00001000 00000046 -- JMP T5:
0x00000042:                   -- T4_PASS:
0x00000042: 0000080F 00000004 -- SETR P 0x4
0x00000044: 0000501F          -- TXR P                 // Expect: 00000004
0x00000045: 00005001          -- NEWLINE
                              -- 
                              -- // --- Test JMPS: jump if sign (negative) ---
0x00000046:                   -- T5:
0x00000046: 00000800 00000000 -- SETR A 0x0
0x00000048: 00000850          -- DECR A                // A = 0xFFFFFFFF (negative)
0x00000049: 00001013 00000051 -- JMPS T5_PASS:
0x0000004B: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF
0x0000004D: 0000501F          -- TXR P
0x0000004E: 00005001          -- NEWLINE
0x0000004F: 00001000 00000055 -- JMP T6:
0x00000051:                   -- T5_PASS:
0x00000051: 0000080F 00000005 -- SETR P 0x5
0x00000053: 0000501F          -- TXR P                 // Expect: 00000005
0x00000054: 00005001          -- NEWLINE
                              -- 
                              -- // --- Test JMPNS: jump if not sign (positive) ---
0x00000055:                   -- T6:
0x00000055: 00000800 00000001 -- SETR A 0x1
0x00000057: 00000810 00000000 -- ADDV A 0x0             // Clear stale sign flag (A=1, positive)
0x00000059: 00001014 00000061 -- JMPNS T6_PASS:
0x0000005B: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF
0x0000005D: 0000501F          -- TXR P
0x0000005E: 00005001          -- NEWLINE
0x0000005F: 00001000 00000065 -- JMP T7:
0x00000061:                   -- T6_PASS:
0x00000061: 0000080F 00000006 -- SETR P 0x6
0x00000063: 0000501F          -- TXR P                 // Expect: 00000006
0x00000064: 00005001          -- NEWLINE
                              -- 
                              -- // --- Test JMPLT: signed less than ---
0x00000065:                   -- T7:
0x00000065: 00000800 00000005 -- SETR A 0x5
0x00000067: 00000801 00000010 -- SETR B 0x10
0x00000069: 00000F00          -- CMPLTRR A             // A(5) < B(16)? yes
0x0000006A: 00001015 00000072 -- JMPLT T7_PASS:
0x0000006C: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF
0x0000006E: 0000501F          -- TXR P
0x0000006F: 00005001          -- NEWLINE
0x00000070: 00001000 00000076 -- JMP T8:
0x00000072:                   -- T7_PASS:
0x00000072: 0000080F 00000007 -- SETR P 0x7
0x00000074: 0000501F          -- TXR P                 // Expect: 00000007
0x00000075: 00005001          -- NEWLINE
                              -- 
                              -- // --- Test JMPGT: signed greater than ---
0x00000076:                   -- T8:
0x00000076: 00000800 00000010 -- SETR A 0x10
0x00000078: 00000801 00000005 -- SETR B 0x5
0x0000007A: 00000F20          -- CMPGTRR A             // A(16) > B(5)? yes
0x0000007B: 00001017 00000083 -- JMPGT T8_PASS:
0x0000007D: 0000080F FFFFFFFF -- SETR P 0xFFFFFFFF
0x0000007F: 0000501F          -- TXR P
0x00000080: 00005001          -- NEWLINE
0x00000081: 00001000 00000087 -- JMP DONE:
0x00000083:                   -- T8_PASS:
0x00000083: 0000080F 00000008 -- SETR P 0x8
0x00000085: 0000501F          -- TXR P                 // Expect: 00000008
0x00000086: 00005001          -- NEWLINE
                              -- 
0x00000087:                   -- DONE:
0x00000087: 00003070 000000FF -- LEDV 0xFF
0x00000089: 0000F011          -- HALT
