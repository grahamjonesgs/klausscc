// test_mem0.kla — Diagnostic: read address 0 and output
//
// Reads the 32-bit word at byte address 0 (heap_start, set by assembler)
// and transmits it as 8 hex digits via UART AND displays it on both
// 7-segment displays (7SEGR: upper 16 bits on display 1, lower 16 on display 2).
//
// Usage: assemble standalone (no C runtime / libc needed)
//   assembler test_mem0.kla
//
// Expected output: the byte address of the first heap word.
// If byte-addressed and ~5000 bytes of code:  0x000013B0
// If word-addressed (old era):               smaller value e.g. 0x000004EC

_start
SETR A 0x8000000    // SP = top of DDR RAM
SETSP A
SETR P 0
DELAYV 0x0500       // let UART and board settle

// Read the 32-bit word at byte address 0 into A
SETR O 0
MEMREADRR A O       // A = mem[0]  (heap_start placed here by assembler)

// Send via UART as 8 hex digits
TXR A
NEWLINE

// Display all 32 bits on both 7-segment displays
// Upper 16 bits → display 1, lower 16 bits → display 2
7SEGR A

HALT

!include libc.kla
