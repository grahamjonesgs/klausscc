                              -- // Test 18: Rotate Instructions
                              -- // Tests: ROLR, RORR, ROLV, RORV, ROLRR, RORRR
                              -- // Expected UART output:
                              -- //   00000002  (ROLR: rotate 0x1 left 1)
                              -- //   80000000  (RORR: rotate 0x1 right 1, bit wraps to MSB)
                              -- //   00000100  (ROLV: rotate 0x1 left 8)
                              -- //   01000000  (RORV: rotate 0x1 right 8)
                              -- //   00000010  (ROLRR: rotate 0x1 left by B=4)
                              -- //   10000000  (RORRR: rotate 0x1 right by B=4)
                              -- //   FFFFFFFF  (ROLR: all-ones is rotate invariant)
                              -- //   00000003  (ROLR: 0x80000001 left 1, MSB wraps to bit 0)
                              -- //   C0000000  (RORR: 0x80000001 right 1, bit 0 wraps to MSB)
                              -- // Expected 7SEG: 0x12
                              -- // Expected LEDs: 0xFF = all pass
                              -- 
                              -- _start
0x00000000: 0000F013 00000500 -- DELAYV 0x0500
0x00000002: 00003071 00000012 -- 7SEG1V 0x12
0x00000004: 00005001          -- NEWLINE
                              -- 
                              -- // ROLR: rotate left by 1
0x00000005: 00000800 00000001 -- SETR A 0x00000001
0x00000007: 00000F80          -- ROLR A
0x00000008: 00005010          -- TXR A                  // Expect: 00000002
0x00000009: 00005001          -- NEWLINE
                              -- 
                              -- // RORR: rotate right by 1 (bit 0 wraps to bit 31)
0x0000000A: 00000800 00000001 -- SETR A 0x00000001
0x0000000C: 00000F90          -- RORR A
0x0000000D: 00005010          -- TXR A                  // Expect: 80000000
0x0000000E: 00005001          -- NEWLINE
                              -- 
                              -- // ROLV: rotate left by N bits
0x0000000F: 00000800 00000001 -- SETR A 0x00000001
0x00000011: 00000FC0 00000008 -- ROLV A 8
0x00000013: 00005010          -- TXR A                  // Expect: 00000100
0x00000014: 00005001          -- NEWLINE
                              -- 
                              -- // RORV: rotate right by N bits
0x00000015: 00000800 00000001 -- SETR A 0x00000001
0x00000017: 00000FD0 00000008 -- RORV A 8
0x00000019: 00005010          -- TXR A                  // Expect: 01000000
0x0000001A: 00005001          -- NEWLINE
                              -- 
                              -- // ROLRR: rotate left by register amount
0x0000001B: 00000800 00000001 -- SETR A 0x00000001
0x0000001D: 00000801 00000004 -- SETR B 4
0x0000001F: 0000B001          -- ROLRR A B
0x00000020: 00005010          -- TXR A                  // Expect: 00000010
0x00000021: 00005001          -- NEWLINE
                              -- 
                              -- // RORRR: rotate right by register amount
0x00000022: 00000800 00000001 -- SETR A 0x00000001
0x00000024: 00000801 00000004 -- SETR B 4
0x00000026: 0000B101          -- RORRR A B
0x00000027: 00005010          -- TXR A                  // Expect: 10000000
0x00000028: 00005001          -- NEWLINE
                              -- 
                              -- // ROLR on all-ones: invariant
0x00000029: 00000800 FFFFFFFF -- SETR A 0xFFFFFFFF
0x0000002B: 00000F80          -- ROLR A
0x0000002C: 00005010          -- TXR A                  // Expect: FFFFFFFF
0x0000002D: 00005001          -- NEWLINE
                              -- 
                              -- // ROLR with MSB set: 0x80000001 rotated left = 0x00000003
                              -- // bit 31 wraps to bit 0, bit 0 moves to bit 1
0x0000002E: 00000800 80000001 -- SETR A 0x80000001
0x00000030: 00000F80          -- ROLR A
0x00000031: 00005010          -- TXR A                  // Expect: 00000003
0x00000032: 00005001          -- NEWLINE
                              -- 
                              -- // RORR with bit 0 and MSB: 0x80000001 rotated right
                              -- // bit 0 wraps to bit 31 (already set), bit 31 moves to bit 30
                              -- // 1000...0001 -> 1100...0000 = 0xC0000000
0x00000033: 00000800 80000001 -- SETR A 0x80000001
0x00000035: 00000F90          -- RORR A
0x00000036: 00005010          -- TXR A                  // Expect: C0000000
0x00000037: 00005001          -- NEWLINE
                              -- 
0x00000038: 00003070 000000FF -- LEDV 0xFF
0x0000003A: 0000F011          -- HALT
