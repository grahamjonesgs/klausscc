                              -- // ----------------------------------------------------------------
                              -- // BSEARCH_FUNC: Binary search on sorted array
                              -- // Input:  I = base address, G = target, C = low index, F = high index
                              -- // Output: E = index of target, or 0xFFFFFFFF if not found
                              -- // Uses CMPLERR+JMPLE, CMPGERR+JMPGE, DIVV, LDIDXR
                              -- // Note: CMPLERR/CMPGERR require register A, so values are COPY'd to A.
                              -- // ----------------------------------------------------------------
0x000000FD:                   -- BSEARCH_FUNC:
0x000000FD: 00004007          -- PUSH H
                              -- 
0x000000FE:                   -- BSR_CHECK:
                              -- // Is low <= high? (CMPLERR compares A with implicit B)
0x000000FE: 00000102          -- COPY A C               // A = low
0x000000FF: 00000115          -- COPY B F               // B = high
0x00000100: 00009101          -- CMPLERR A B            // A <= B? (low <= high?)
0x00000101: 00001016 00000105 -- JMPLE BSR_SEARCH:      // yes -> keep searching
0x00000103: 00001000 0000011D -- JMP BSR_NOT_FOUND:     // no -> target absent
                              -- 
0x00000105:                   -- BSR_SEARCH:
                              -- // mid = (low + high) / 2
0x00000105: 00000142          -- COPY E C
0x00000106: 00000645          -- ADDRR E F              // E = low + high
0x00000107: 00000B94 00000002 -- DIVV E 2               // E = mid (DIVV: divide by immediate)
                              -- 
                              -- // Load arr[mid] via LDIDXR (0x4 = register E index)
0x00000109: 00000E38 00000004 -- LDIDXR D I 0x4         // D = mem[I + E] = arr[mid]
                              -- 
                              -- // Compare arr[mid] with target
0x0000010B: 00000103          -- COPY A D               // A = arr[mid]
0x0000010C: 00000116          -- COPY B G               // B = target
0x0000010D: 00000501          -- CMPRR A B              // sets flags for equal check
0x0000010E: 00001003 0000011B -- JMPE BSR_FOUND:        // arr[mid] == target
                              -- 
                              -- // Decide search direction: CMPGERR + JMPGE
0x00000110: 00009301          -- CMPGERR A B            // A >= B? (arr[mid] >= target?)
0x00000111: 00001018 00000117 -- JMPGE BSR_LEFT:        // yes -> search left half
                              -- 
                              -- // arr[mid] < target -> search right half
0x00000113: 00000124          -- COPY C E
0x00000114: 00000842          -- INCR C                 // low = mid + 1
0x00000115: 00001000 000000FE -- JMP BSR_CHECK:
                              -- 
0x00000117:                   -- BSR_LEFT:
0x00000117: 00000154          -- COPY F E
0x00000118: 00000855          -- DECR F                 // high = mid - 1
0x00000119: 00001000 000000FE -- JMP BSR_CHECK:
                              -- 
0x0000011B:                   -- BSR_FOUND:
0x0000011B: 00004017          -- POP H
0x0000011C: 00001012          -- RET
                              -- 
0x0000011D:                   -- BSR_NOT_FOUND:
0x0000011D: 00000804 FFFFFFFF -- SETR E 0xFFFFFFFF
0x0000011F: 00004017          -- POP H
0x00000120: 00001012          -- RET
