0x00000134: 00001017 00000138 -- JMPGT IP_CONTINUE:     // candidate > divisor -> keep testing
0x00000136: 00001000 00000141 -- JMP IP_IS_PRIME:       // candidate <= divisor -> prime
                              -- 
0x00000138:                   -- IP_CONTINUE:
0x00000138: 00000102          -- COPY A C               // A = candidate
0x00000139: 00008601          -- MODRR A B              // A = candidate % B (divisor)
0x0000013A: 00000830 00000000 -- CMPRV A 0x0
0x0000013C: 00001003 00000145 -- JMPE IP_NOT_PRIME:     // divisible -> not prime
                              -- 
0x0000013E: 00000841          -- INCR B                 // next divisor
0x0000013F: 00001000 00000133 -- JMP IP_LOOP:
