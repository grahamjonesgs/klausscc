                              -- // Test 21: Extended Multi-Algorithm CPU Benchmark
                              -- // Stress-tests the CPU across seven phases, exercising instructions that have
                              -- // no coverage or minimal coverage in the existing test suite.
                              -- //
                              -- // Untested opcodes exercised: BSETRR, JMPNC, PUSHV
                              -- // Barely-tested opcodes exercised: STIDX, STIDXR, LDIDX, LDIDXR, ORV, ANDV,
                              -- //   XORV, SHLV, SHRV, BITREV, MULHURR, DIVV, CMPLERR, CMPGERR, CMPGTRR,
                              -- //   JMPLE, JMPGE, JMPC, POPCNT, CLZ
                              -- //
                              -- // Expected UART output:
                              -- //   00000037  (fibonacci: fib[9] = 55)
                              -- //   00000005  (fibonacci: fib[4] = 5)
                              -- //   00000001  (bubble sort: smallest of {9,3,7,1,5})
                              -- //   00000009  (bubble sort: largest after sort)
                              -- //   00000002  (binary search: index of 5 in sorted {1,3,5,7,9})
                              -- //   FFFFFFFF  (binary search: 6 not found)
                              -- //   0000ABCD  (bit ops: pack nibbles via SHLV + ORV)
                              -- //   0000000B  (bit ops: extract nibble via SHRV + ANDV)
                              -- //   00000055  (bit ops: 0xFF XORV 0xAA)
                              -- //   B3D50000  (bit ops: BITREV of 0x0000ABCD)
                              -- //   00000008  (bit ops: BSETRR set bit 3 of zero = 8)
                              -- //   0000000A  (bit ops: POPCNT of 0xABCD = 10)
                              -- //   00000010  (bit ops: CLZ of 0x0000ABCD = 16)
                              -- //   FFFFFFFE  (multiply: MULHURR high of 0xFFFFFFFF * 0xFFFFFFFF)
                              -- //   00000001  (multiply: MULURR low word)
                              -- //   00000002  (flags: JMPC + JMPNC both passed)
                              -- //   00000006  (GCD: gcd(48, 18) = 6)
                              -- //   00000008  (primes: count from 2 to 20)
                              -- //   00000013  (primes: largest prime <= 20 = 19)
                              -- // Expected 7SEG: 0x15
                              -- // Expected LEDs: 0xFF = all pass
                              -- 
                              -- _start
