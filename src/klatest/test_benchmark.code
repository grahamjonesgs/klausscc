0x00000128: 00000101          -- COPY A B               // A = old divisor
0x00000129: 00000112          -- COPY B C               // B = remainder
0x0000012A: 00001000 00000122 -- JMP GCD_LOOP:
0x0000012C:                   -- GCD_RET:
0x0000012C: 00004012          -- POP C
0x0000012D: 00001012          -- RET
