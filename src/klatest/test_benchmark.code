                              -- // Uses MODRR (must use register A).
                              -- // ----------------------------------------------------------------
0x0000012E:                   -- IS_PRIME:
0x0000012E: 00004002          -- PUSH C
0x0000012F: 00000120          -- COPY C A               // C = candidate (saved)
0x00000130: 00004020 00000002 -- PUSHV 2                // exercise PUSHV: push starting divisor
0x00000132: 00004011          -- POP B                  // B = 2
