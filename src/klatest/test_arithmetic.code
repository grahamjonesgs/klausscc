                              -- // Test 02: Arithmetic Operations
                              -- // Tests: ADDRR, MINUSRR, ADDV, MINUSV
                              -- // Expected UART output:
                              -- //   00000030  (ADDRR: 0x10 + 0x20 = 0x30)
                              -- //   00000010  (MINUSRR: 0x30 - 0x20 = 0x10)
                              -- //   0000006E  (ADDV: 0x0A + 100 = 0x6E)
                              -- //   0000005E  (MINUSV: 0x6E - 0x10 = 0x5E)
                              -- //   00000000  (overflow test: 0xFFFFFFFF + 1 wraps to 0)
                              -- // Expected 7SEG: 0x02
                              -- // Expected LEDs: 0xFF = all pass
                              -- 
                              -- _start
0x00000000: 0000F013 00000500 -- DELAYV 0x0500
0x00000002: 00003071 00000002 -- 7SEG1V 0x02
0x00000004: 00005001          -- NEWLINE
                              -- 
                              -- // ADDRR: A + B -> A
0x00000005: 00000800 00000010 -- SETR A 0x10
0x00000007: 00000801 00000020 -- SETR B 0x20
0x00000009: 00000601          -- ADDRR A B
0x0000000A: 00005010          -- TXR A                 // Expect: 00000030
0x0000000B: 00005001          -- NEWLINE
                              -- 
                              -- // MINUSRR: A - B -> A
0x0000000C: 00000701          -- MINUSRR A B
0x0000000D: 00005010          -- TXR A                 // Expect: 00000010
0x0000000E: 00005001          -- NEWLINE
                              -- 
                              -- // ADDV: A + immediate
0x0000000F: 00000800 0000000A -- SETR A 0x0A
0x00000011: 00000810 00000064 -- ADDV A 100            // 0x0A + 100 = 10 + 100 = 110 = 0x6E
0x00000013: 00005010          -- TXR A                 // Expect: 0000006E
0x00000014: 00005001          -- NEWLINE
                              -- 
                              -- // MINUSV: A - immediate
0x00000015: 00000820 00000010 -- MINUSV A 0x10         // 0x6E - 0x10 = 0x5E
0x00000017: 00005010          -- TXR A                 // Expect: 0000005E
0x00000018: 00005001          -- NEWLINE
                              -- 
                              -- // Overflow test: 0xFFFFFFFF + 1 should wrap to 0
0x00000019: 00000800 FFFFFFFF -- SETR A 0xFFFFFFFF
0x0000001B: 00000840          -- INCR A
0x0000001C: 00005010          -- TXR A                 // Expect: 00000000
0x0000001D: 00005001          -- NEWLINE
                              -- 
0x0000001E: 00003070 000000FF -- LEDV 0xFF
0x00000020: 0000F011          -- HALT
