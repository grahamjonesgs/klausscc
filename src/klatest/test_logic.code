                              -- // Test 03: Logic and Bitwise Operations
                              -- // Tests: AND, OR, XOR, ANDV, ORV, XORV, BSWAP
                              -- // Expected UART output:
                              -- //   00000012  (AND: 0xFF & 0x12 = 0x12)
                              -- //   0000FFFF  (OR: 0xFF00 | 0x00FF = 0xFFFF)
                              -- //   0000FF00  (XOR: 0xFFFF ^ 0x00FF = 0xFF00)
                              -- //   000000F0  (ANDV: 0xFF & 0xF0 = 0xF0)
                              -- //   000000FF  (ORV: 0xF0 | 0x0F = 0xFF)
                              -- //   000000F0  (XORV: 0xFF ^ 0x0F = 0xF0)
                              -- //   78563412  (BSWAP: 0x12345678 -> 0x78563412)
                              -- // Expected 7SEG: 0x03
                              -- // Expected LEDs: 0xFF = all pass
                              -- 
                              -- _start
0x00000000: 0000F013 00000500 -- DELAYV 0x0500
0x00000002: 00003071 00000003 -- 7SEG1V 0x03
0x00000004: 00005001          -- NEWLINE
                              -- 
                              -- // AND registers
0x00000005: 00000800 000000FF -- SETR A 0xFF
0x00000007: 00000801 00000012 -- SETR B 0x12
0x00000009: 00000201          -- AND A B
0x0000000A: 00005010          -- TXR A                 // Expect: 00000012
0x0000000B: 00005001          -- NEWLINE
                              -- 
                              -- // OR registers
0x0000000C: 00000800 0000FF00 -- SETR A 0xFF00
0x0000000E: 00000801 000000FF -- SETR B 0x00FF
0x00000010: 00000301          -- OR A B
0x00000011: 00005010          -- TXR A                 // Expect: 0000FFFF
0x00000012: 00005001          -- NEWLINE
                              -- 
                              -- // XOR registers
0x00000013: 00000801 000000FF -- SETR B 0x00FF
0x00000015: 00000401          -- XOR A B
0x00000016: 00005010          -- TXR A                 // Expect: 0000FF00
0x00000017: 00005001          -- NEWLINE
                              -- 
                              -- // ANDV with immediate
0x00000018: 00000800 000000FF -- SETR A 0xFF
0x0000001A: 00000860 000000F0 -- ANDV A 0xF0
0x0000001C: 00005010          -- TXR A                 // Expect: 000000F0
0x0000001D: 00005001          -- NEWLINE
                              -- 
                              -- // ORV with immediate
0x0000001E: 00000870 0000000F -- ORV A 0x0F
0x00000020: 00005010          -- TXR A                 // Expect: 000000FF
0x00000021: 00005001          -- NEWLINE
                              -- 
                              -- // XORV with immediate
0x00000022: 00000880 0000000F -- XORV A 0x0F
0x00000024: 00005010          -- TXR A                 // Expect: 000000F0
0x00000025: 00005001          -- NEWLINE
                              -- 
                              -- // BSWAP endian conversion
0x00000026: 00000800 12345678 -- SETR A 0x12345678
0x00000028: 00000970          -- BSWAP A
0x00000029: 00005010          -- TXR A                 // Expect: 78563412
0x0000002A: 00005001          -- NEWLINE
                              -- 
0x0000002B: 00003070 000000FF -- LEDV 0xFF
0x0000002D: 0000F011          -- HALT
