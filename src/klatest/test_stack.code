                              -- // Test 09: Stack Operations
                              -- // Tests: PUSH, POP, PUSHV, LIFO ordering, nested push/pop
                              -- // Expected UART output:
                              -- //   00000011  (push 0x11, pop back)
                              -- //   00000022  (push 0x11 then 0x22, pop gets 0x22 first - LIFO)
                              -- //   00000011  (second pop gets 0x11)
                              -- //   000000FF  (PUSHV 0xFF, pop it back)
                              -- //   0000000C  (push A=0xA, B=0xB, C=0xC, pop C gets 0xC - LIFO)
                              -- //   0000000B  (pop B gets 0xB)
                              -- //   0000000A  (pop A gets 0xA)
                              -- // Expected 7SEG: 0x09
                              -- // Expected LEDs: 0xFF = all pass
                              -- 
                              -- _start
0x00000000: 0000F013 00003000 -- DELAYV 0x3000
0x00000002: 00003071 00000009 -- 7SEG1V 0x09
0x00000004: 00005001          -- NEWLINE
                              -- 
                              -- // Basic push/pop
0x00000005: 00000800 00000011 -- SETR A 0x11
0x00000007: 00004000          -- PUSH A
0x00000008: 00000800 00000000 -- SETR A 0x0            // Clear A
0x0000000A: 00004010          -- POP A
0x0000000B: 00005010          -- TXR A                 // Expect: 00000011
0x0000000C: 00005001          -- NEWLINE
                              -- 
                              -- // LIFO order test
0x0000000D: 00000800 00000011 -- SETR A 0x11
0x0000000F: 00000801 00000022 -- SETR B 0x22
0x00000011: 00004000          -- PUSH A                // Push 0x11 first
0x00000012: 00004001          -- PUSH B                // Push 0x22 second
0x00000013: 00004012          -- POP C                 // Should get 0x22 (last in, first out)
0x00000014: 00005012          -- TXR C                 // Expect: 00000022
0x00000015: 00005001          -- NEWLINE
0x00000016: 00004012          -- POP C                 // Should get 0x11
0x00000017: 00005012          -- TXR C                 // Expect: 00000011
0x00000018: 00005001          -- NEWLINE
                              -- 
                              -- // PUSHV: push immediate value
0x00000019: 00004020 000000FF -- PUSHV 0xFF
0x0000001B: 00004010          -- POP A
0x0000001C: 00005010          -- TXR A                 // Expect: 000000FF
0x0000001D: 00005001          -- NEWLINE
                              -- 
                              -- // Triple push/pop: verify all three restore correctly
0x0000001E: 00000800 0000000A -- SETR A 0xA
0x00000020: 00000801 0000000B -- SETR B 0xB
0x00000022: 00000802 0000000C -- SETR C 0xC
0x00000024: 00004000          -- PUSH A
0x00000025: 00004001          -- PUSH B
0x00000026: 00004002          -- PUSH C
                              -- 
                              -- // Clear all registers
0x00000027: 00000800 00000000 -- SETR A 0x0
0x00000029: 00000801 00000000 -- SETR B 0x0
0x0000002B: 00000802 00000000 -- SETR C 0x0
                              -- 
                              -- // Pop in reverse order
0x0000002D: 00004012          -- POP C
0x0000002E: 00005012          -- TXR C                 // Expect: 0000000C
0x0000002F: 00005001          -- NEWLINE
0x00000030: 00004011          -- POP B
0x00000031: 00005011          -- TXR B                 // Expect: 0000000B
0x00000032: 00005001          -- NEWLINE
0x00000033: 00004010          -- POP A
0x00000034: 00005010          -- TXR A                 // Expect: 0000000A
0x00000035: 00005001          -- NEWLINE
                              -- 
0x00000036: 00003070 000000FF -- LEDV 0xFF
0x00000038: 0000F011          -- HALT
