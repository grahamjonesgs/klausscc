                              -- // Test 08: Memory Operations
                              -- // Tests: MEMSETRR, MEMREADRR, MEMSETR, MEMREADR
                              -- // Expected UART output:
                              -- //   000000AA  (MEMSETRR/MEMREADRR: write 0xAA, read back)
                              -- //   000000BB  (MEMSETR/MEMREADR: write 0xBB to fixed addr, read back)
                              -- //   DEADBEEF  (write 0xDEADBEEF to data area, read back)
                              -- //   00000003  (sequential write 1,2,3 then read third value)
                              -- // Expected 7SEG: 0x08
                              -- // Expected LEDs: 0xFF = all pass
                              -- 
                              -- _start
0x00000000: 0000F013 00000500 -- DELAYV 0x0500
0x00000002: 00003071 00000008 -- 7SEG1V 0x08
0x00000004: 00005001          -- NEWLINE
                              -- 
                              -- // Test MEMSETRR / MEMREADRR: register-addressed write and read
0x00000005: 00000800 00000038 -- SETR A #BUF1          // A = address of buffer
0x00000007: 00000801 000000AA -- SETR B 0xAA           // B = value to write
0x00000009: 00007010          -- MEMSETRR B A          // mem[A] = 0xAA
0x0000000A: 00000802 00000000 -- SETR C 0x0            // Clear C
0x0000000C: 00007120          -- MEMREADRR C A         // C = mem[A]
0x0000000D: 00005012          -- TXR C                 // Expect: 000000AA
0x0000000E: 00005001          -- NEWLINE
                              -- 
                              -- // Test MEMSETR / MEMREADR: value-addressed write and read
0x0000000F: 00000801 000000BB -- SETR B 0xBB
0x00000011: 00007201 00000100 -- MEMSETR B 0x100       // mem[0x100] = 0xBB
0x00000013: 00000802 00000000 -- SETR C 0x0
0x00000015: 00007212 00000100 -- MEMREADR C 0x100      // C = mem[0x100]
0x00000017: 00005012          -- TXR C                 // Expect: 000000BB
0x00000018: 00005001          -- NEWLINE
                              -- 
                              -- // Test with larger value
0x00000019: 00000800 00000038 -- SETR A #BUF1
0x0000001B: 00000801 DEADBEEF -- SETR B 0xDEADBEEF
0x0000001D: 00007010          -- MEMSETRR B A
0x0000001E: 00000802 00000000 -- SETR C 0x0
0x00000020: 00007120          -- MEMREADRR C A
0x00000021: 00005012          -- TXR C                 // Expect: DEADBEEF
0x00000022: 00005001          -- NEWLINE
                              -- 
                              -- // Test sequential memory: write 3 values, read back third
0x00000023: 00000800 00000042 -- SETR A #BUF2
0x00000025: 00000801 00000001 -- SETR B 0x1
0x00000027: 00007010          -- MEMSETRR B A          // mem[BUF2+0] = 1
0x00000028: 00000840          -- INCR A
0x00000029: 00000801 00000002 -- SETR B 0x2
0x0000002B: 00007010          -- MEMSETRR B A          // mem[BUF2+1] = 2
0x0000002C: 00000840          -- INCR A
0x0000002D: 00000801 00000003 -- SETR B 0x3
0x0000002F: 00007010          -- MEMSETRR B A          // mem[BUF2+2] = 3
0x00000030: 00000802 00000000 -- SETR C 0x0
0x00000032: 00007120          -- MEMREADRR C A         // Read back last written (3)
0x00000033: 00005012          -- TXR C                 // Expect: 00000003
0x00000034: 00005001          -- NEWLINE
                              -- 
0x00000035: 00003070 000000FF -- LEDV 0xFF
0x00000037: 0000F011          -- HALT
                              -- 
0x00000038: 00000000          -- #BUF1 10
0x00000039: 00000000          -- #BUF1 10
0x0000003A: 00000000          -- #BUF1 10
0x0000003B: 00000000          -- #BUF1 10
0x0000003C: 00000000          -- #BUF1 10
0x0000003D: 00000000          -- #BUF1 10
0x0000003E: 00000000          -- #BUF1 10
0x0000003F: 00000000          -- #BUF1 10
0x00000040: 00000000          -- #BUF1 10
0x00000041: 00000000          -- #BUF1 10
0x00000042: 00000000          -- #BUF2 10
0x00000043: 00000000          -- #BUF2 10
0x00000044: 00000000          -- #BUF2 10
0x00000045: 00000000          -- #BUF2 10
0x00000046: 00000000          -- #BUF2 10
0x00000047: 00000000          -- #BUF2 10
0x00000048: 00000000          -- #BUF2 10
0x00000049: 00000000          -- #BUF2 10
0x0000004A: 00000000          -- #BUF2 10
0x0000004B: 00000000          -- #BUF2 10
