                              -- // Test 10: Subroutine CALL and RET
                              -- // Tests: CALL, RET, nested calls, register preservation across calls
                              -- // Expected UART output:
                              -- //   00000001  (simple CALL/RET executed, returned successfully)
                              -- //   0000000A  (register preserved across call via push/pop)
                              -- //   00000003  (nested call: main->func1->func2, result = 3)
                              -- //   00000042  (conditional CALLE taken after CMPRR equal)
                              -- //   00000099  (CALLNE not taken when equal, continues to output 0x99)
                              -- // Expected 7SEG: 0x0A
                              -- // Expected LEDs: 0xFF = all pass
                              -- 
                              -- _start
0x00000000: 0000F013 00000500 -- DELAYV 0x0500
0x00000002: 00003071 0000000A -- 7SEG1V 0x0A
0x00000004: 00005001          -- NEWLINE
                              -- 
                              -- // --- Simple CALL/RET ---
0x00000005: 00000800 00000000 -- SETR A 0x0
0x00000007: 00001009 00000030 -- CALL SIMPLE_FUNC:
                              -- // If we get here, RET worked
0x00000009: 00005010          -- TXR A                 // Expect: 00000001 (set by SIMPLE_FUNC)
0x0000000A: 00005001          -- NEWLINE
                              -- 
                              -- // --- Register preservation across call ---
0x0000000B: 00000800 0000000A -- SETR A 0x0A
0x0000000D: 00004000          -- PUSH A                // Save A
0x0000000E: 00001009 00000033 -- CALL CLOBBER_A:       // This function changes A
0x00000010: 00004010          -- POP A                 // Restore A
0x00000011: 00005010          -- TXR A                 // Expect: 0000000A (preserved)
0x00000012: 00005001          -- NEWLINE
                              -- 
                              -- // --- Nested calls ---
0x00000013: 00000800 00000000 -- SETR A 0x0
0x00000015: 00001009 00000036 -- CALL NEST_OUTER:
0x00000017: 00005010          -- TXR A                 // Expect: 00000003 (incremented by 3 nested calls)
0x00000018: 00005001          -- NEWLINE
                              -- 
                              -- // --- Conditional CALLE: call if equal ---
0x00000019: 00000800 00000010 -- SETR A 0x10
0x0000001B: 00000801 00000010 -- SETR B 0x10
0x0000001D: 00000501          -- CMPRR A B             // Equal
0x0000001E: 0000100C 00000040 -- CALLE COND_FUNC:      // Should be called
0x00000020: 00005010          -- TXR A                 // Expect: 00000042 (set by COND_FUNC)
0x00000021: 00005001          -- NEWLINE
                              -- 
                              -- // --- Conditional CALLNE: should NOT call when equal ---
0x00000022: 00000800 00000050 -- SETR A 0x50
0x00000024: 00000801 00000050 -- SETR B 0x50
0x00000026: 00000501          -- CMPRR A B             // Equal
0x00000027: 0000100D 00000040 -- CALLNE COND_FUNC:     // Should NOT be called
0x00000029: 00000800 00000099 -- SETR A 0x99
0x0000002B: 00005010          -- TXR A                 // Expect: 00000099 (CALLNE was skipped)
0x0000002C: 00005001          -- NEWLINE
                              -- 
0x0000002D: 00003070 000000FF -- LEDV 0xFF
0x0000002F: 0000F011          -- HALT
                              -- 
                              -- // --- Subroutines ---
                              -- 
0x00000030:                   -- SIMPLE_FUNC:
0x00000030: 00000800 00000001 -- SETR A 0x1
0x00000032: 00001012          -- RET
                              -- 
0x00000033:                   -- CLOBBER_A:
0x00000033: 00000800 000000FF -- SETR A 0xFF           // Clobbers A
0x00000035: 00001012          -- RET
                              -- 
0x00000036:                   -- NEST_OUTER:
0x00000036: 00000840          -- INCR A                // A = 1
0x00000037: 00001009 0000003A -- CALL NEST_MIDDLE:
0x00000039: 00001012          -- RET
                              -- 
0x0000003A:                   -- NEST_MIDDLE:
0x0000003A: 00000840          -- INCR A                // A = 2
0x0000003B: 00001009 0000003E -- CALL NEST_INNER:
0x0000003D: 00001012          -- RET
                              -- 
0x0000003E:                   -- NEST_INNER:
0x0000003E: 00000840          -- INCR A                // A = 3
0x0000003F: 00001012          -- RET
                              -- 
0x00000040:                   -- COND_FUNC:
0x00000040: 00000800 00000042 -- SETR A 0x42
0x00000042: 00001012          -- RET
